rules_version = '2';

// Aria's Journal + Summer Tracker — Firestore rules (project aria-tracker-c89d3).
//
// MERGED 2026-07-03 from the console-managed production rules (release
// 54dc7fce…, 2026-07-02) + the journal's rules. The tracker's two matches keep
// their exact production semantics — including the booksSeed >= 6 version gate
// that ended the June/July write-war. This file is now the source of truth;
// deploy with: firebase deploy --only firestore:rules --project aria-tracker-c89d3
//
// Roles: production email checks (primary, matches live rules) + UID hardcodes
// + families/aria/members/{uid} role docs (extensible path; emulator tests use
// UIDs). The parent PIN in the journal UI is a UX gate — THIS is the boundary.

service cloud.firestore {
  match /databases/{database}/documents {

    function parentEmail() { return 'chitts@gmail.com'; }
    function ariaEmail()   { return 'aria.gautam01@gmail.com'; }
    function parentUid() { return 'ForoefZlHRbJIwZgCraAxAUfq1n2'; }
    function childUid()  { return 'O93lhqGLBye4TLzYrREpRaEBm972'; }

    function signedIn() { return request.auth != null; }
    function authEmail() {
      return signedIn() && 'email' in request.auth.token ? request.auth.token.email : '';
    }

    function memberPath() {
      return /databases/$(database)/documents/families/aria/members/$(request.auth.uid);
    }
    function memberRole() {
      return exists(memberPath()) ? get(memberPath()).data.role : '';
    }

    function isParent() {
      return signedIn()
        && (authEmail() == parentEmail() || request.auth.uid == parentUid() || memberRole() == 'parent');
    }
    function isChild() {
      return signedIn()
        && (authEmail() == ariaEmail() || request.auth.uid == childUid() || memberRole() == 'child');
    }
    function isFamily() { return isParent() || isChild(); }

    // ── Summer Tracker (production semantics preserved verbatim) ─────────
    // Aria's self-marks ("claims") — either family member may write this one
    // doc. The journal's sync adapter writes journal.<dateKey> here.
    match /families/aria-claims {
      allow read, write: if isFamily();
    }

    // Main tracker data — both can read; only the parent can change it, and
    // only from a CURRENT app version (stale cached clients write
    // booksSeed < 6 and get rejected — this ended the June/July write-war).
    match /families/aria {
      allow read:  if isFamily();
      allow write: if isParent() && request.resource.data.booksSeed >= 6;

      // Journal role docs (rules-readable role source for future members).
      match /members/{uid} {
        allow read: if isFamily();
        allow write: if isParent();
      }
    }

    // ── Journal days ────────────────────────────────────────────────────
    // Doc id: {familyId}_{childUid}_{yyyyMMdd}. The child may only touch
    // days keyed to her own uid; the parent may touch (and delete) any.
    match /journalDays/{dayId} {
      function ownsDay() { return dayId.split('_')[1] == request.auth.uid; }

      allow read: if isFamily();
      allow create, update: if isParent() || (isChild() && ownsDay());
      allow delete: if isParent();

      match /sections/{sectionId} {
        allow read: if isFamily();
        allow create, update: if isParent() || (isChild() && ownsDay());
        // The child can archive (status: "archived") but NEVER hard-delete.
        allow delete: if isParent();

        // Frozen pre-edit text snapshots (overwrite insurance). Immutable
        // once written; only the parent can prune them.
        match /revisions/{revisionId} {
          allow read: if isFamily();
          allow create: if isParent() || (isChild() && ownsDay());
          allow update: if false;
          allow delete: if isParent();
        }

        match /reviews/{reviewId} {
          allow read: if isFamily();
          // The child appends reviews and may update ONLY her correction
          // outcomes and re-check results; the review body is immutable to
          // her. Parent has full control.
          allow create: if isParent() || (isChild() && ownsDay());
          allow update: if isParent()
            || (isChild() && ownsDay()
                && request.resource.data.diff(resource.data).affectedKeys()
                     .hasOnly(['correctionOutcomes', 'postFixRecheck']));
          allow delete: if isParent();
        }
      }
    }

    // ── Journal app meta (settings, word shelf, favorites, parent notes) ──
    // Family-writable; parent-only knobs inside are gated by the PIN in the
    // UI (an acceptable UX gate for non-security settings per spec §11).
    match /journalMeta/{familyId} {
      allow read, write: if isFamily();
    }

    // ── Weekly insights & prompt bank ──────────────────────────────────
    match /weeklyInsights/{insightId} {
      allow read: if isParent();     // parent-only surface (child gets her voice card via journalMeta)
      allow write: if isParent();
    }
    match /prompt_bank/{promptId} {
      allow read: if isFamily();
      allow write: if isParent();
    }
  }
}
